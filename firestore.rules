rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPER FUNKCIJE ──────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMasterAdmin() {
      return isAuth() && getUserData().role == 'master_admin';
    }

    function isFleetAdmin(companyId) {
      return isAuth()
        && getUserData().role == 'fleet_admin'
        && getUserData().companyId == companyId;
    }

    function isDriver(companyId) {
      return isAuth()
        && getUserData().role == 'driver'
        && getUserData().companyId == companyId;
    }

    function isCompanyMember(companyId) {
      return isFleetAdmin(companyId) || isDriver(companyId) || isMasterAdmin();
    }

    // ── KORISNICI ────────────────────────────────────────────
    match /users/{userId} {
      // Korisnik može da čita samo svoj profil, master admin čita sve
      allow read: if isAuth() && (request.auth.uid == userId || isMasterAdmin());
      // Kreira se pri registraciji (master admin kreira naloge)
      allow create: if isMasterAdmin();
      // Update: sam korisnik (ograničena polja) ili master/fleet admin
      allow update: if isAuth() && (
        request.auth.uid == userId
        || isMasterAdmin()
        // Fleet admin može da update-uje vozače u svojoj firmi
        || (getUserData().role == 'fleet_admin'
            && resource.data.companyId == getUserData().companyId
            && resource.data.role == 'driver')
      );
      allow delete: if isMasterAdmin();
    }

    // ── KOMPANIJE ────────────────────────────────────────────
    match /companies/{companyId} {
      allow read: if isCompanyMember(companyId);
      allow create, update, delete: if isMasterAdmin();

      // ── VOZILA ──────────────────────────────────────────
      match /vehicles/{vehicleId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isMasterAdmin() || isFleetAdmin(companyId);
      }

      // ── VOZAČI ──────────────────────────────────────────
      match /drivers/{driverId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isMasterAdmin() || isFleetAdmin(companyId);
      }

      // ── ZADUŽENJA ────────────────────────────────────────
      match /assignments/{assignmentId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isMasterAdmin() || isFleetAdmin(companyId);
        // Vozač može da update-uje samo km i status svog zaduženja
        allow update: if isDriver(companyId)
          && resource.data.driverUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['endKm', 'driverEndKm', 'driverKmNote', 'updatedAt']);
      }

      // ── VOŽNJE (TRIPS) ────────────────────────────────────
      match /trips/{tripId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId);
        // Vozač može update-ovati samo svoje vožnje
        allow update, delete: if isMasterAdmin() || isFleetAdmin(companyId)
          || (isDriver(companyId) && resource.data.driverUid == request.auth.uid);
      }

      // ── TOČENJA GORIVA ────────────────────────────────────
      match /fuelings/{fuelingId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId);
        allow update, delete: if isMasterAdmin() || isFleetAdmin(companyId)
          || (isDriver(companyId) && resource.data.driverUid == request.auth.uid);
      }

      // ── INCIDENTI (kvarovi, štete, nezgode) ───────────────
      match /incidents/{incidentId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId);
        // Status može da menja samo admin
        allow update: if isMasterAdmin() || isFleetAdmin(companyId)
          || (isDriver(companyId)
              && resource.data.reportedByUid == request.auth.uid
              && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']));
        allow delete: if isMasterAdmin() || isFleetAdmin(companyId);
      }

      // ── SERVISI ──────────────────────────────────────────
      match /services/{serviceId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isMasterAdmin() || isFleetAdmin(companyId);
      }

      // ── NOTIFIKACIJE ─────────────────────────────────────
      match /notifications/{notifId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId);
        allow update: if isAuth()
          && (isMasterAdmin() || isFleetAdmin(companyId)
              || resource.data.recipientUid == request.auth.uid);
        allow delete: if isMasterAdmin() || isFleetAdmin(companyId);
      }
    }
  }
}

    // ── ADMIN NOTIFIKACIJE (pending zahtevi) ──────────────────
    // Napomena: ovo ide VAN companies bloka, na root nivou